# Server Configuration
PORT=3000

# Database
# Example for local Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/express_pizza?schema=public"

# Security (JWT)
JWT_SECRET="super-secret-jwt-key-for-express-pizza"

# External Integrations (Mocked/Variables)
SMS_API_KEY="your-sms-by-api-key"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# bePaid Acquiring (Sprint 3)
BEPAID_SHOP_ID="your_shop_id"
BEPAID_SECRET_KEY="your_secret_key"
BEPAID_TEST_MODE="true"

# Hardware (Sprint 4)
PRINTER_IP="192.168.1.100"
PRINTER_PORT="9100"

# Feature Flags
ENABLE_IMAGE_FETCH_JOB="false"
